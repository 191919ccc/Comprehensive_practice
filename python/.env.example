KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=stock_realtime_topic
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=stock_stream
HDFS_OUTPUT_PATH=/user/fqy/stock_output
HDFS_CHECKPOINT_PATH=/user/fqy/stock_checkpoint
STOCK_SYMBOLS=AAPL,MSFT,NVDA,TSLA,GOOGL
QUOTE_INTERVAL_SECONDS=5
QUOTE_SOURCE=yahoo
QUOTE_SOURCES=yahoo,eastmoney,sina,tencent,stooq
QUOTE_OUTPUT=data/stock_symbols.json
HTTP_TIMEOUT_SECONDS=10
ML_MODEL_DIR=models
ML_MIN_TRAIN_SIZE=12
ML_MAX_TRAIN_ROWS=24000
ML_REQUIRE_GPU=false
ML_LSTM_EPOCHS=10
ML_LSTM_FINE_TUNE_EPOCHS=2
ML_LSTM_EARLY_STOP_PATIENCE=8
ML_LSTM_MAX_SEQUENCES=6000
ML_TRAINING_LOOKBACK_DAYS=0
ML_DIRECTION_THRESHOLD=0.020
ML_PREDICTION_HORIZON=5
ML_TARGET_MODE=downside_risk
ML_RISK_DOWNSIDE_THRESHOLD=0.030
ML_RISK_VOLATILITY_THRESHOLD=0.060
ML_RISK_ALERT_MIN_RETURN=0.010
ML_ALERT_CONFIDENCE_THRESHOLD=0.64
ML_ALERT_UP_CONFIDENCE_THRESHOLD=0.64
ML_ALERT_DOWN_CONFIDENCE_THRESHOLD=0.75
